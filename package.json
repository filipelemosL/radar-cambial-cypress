{
  "name": "radar-cambial-cypress-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.mjs",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "typecheck:tests": "tsc -p tsconfig.cypress.json",
    "preview": "vite preview",
    "start:test": "concurrently -k -n API,WEB -c magenta,cyan \"npm:dev:api\" \"vite --host 127.0.0.1\"",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:component": "cypress run --component",
    "test:e2e": "start-server-and-test start:test http://127.0.0.1:5173 cy:run",
    "test": "npm run build && npm run test:e2e"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "6.0.3",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cypress": "14.5.4",
    "start-server-and-test": "^2.0.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
